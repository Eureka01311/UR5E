    <material name="leaf_mat" rgba="0.1 0.5 0.1 0.8" specular="0.1" shininess="0.1"/>
  </asset>

  <equality>
      <weld name="apple_1_weld" body1="apple_1" body2="tree_branch_1" 
            solref="0.02 1" solimp="0.9 0.95 0.001"/>
  </equality>

  <equality>
      <weld name="apple_2_weld" body1="apple_2" body2="tree_branch_1" 
            solref="0.02 1" solimp="0.9 0.95 0.001"/>
  </equality>

  <equality>
      <weld name="apple_3_weld" body1="apple_3" body2="tree_branch_1" 
            solref="0.02 1" solimp="0.9 0.95 0.001"/>
  </equality>

  <sensor>
      <force name="apple_force_sensor_1" site="apple_force_site_1"/>
  </sensor>

  <sensor>
      <force name="apple_force_sensor_2" site="apple_force_site_2"/>
  </sensor>

  <sensor>
      <force name="apple_force_sensor_3" site="apple_force_site_3"/>
  </sensor>

