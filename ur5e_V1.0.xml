        </default>
        <default class="fingertip_visual">
          <geom pos="0 0 0.0267" material="allegro_white" mesh="link_3.0_tip"/>
        </default>
        <default class="thumbtip_visual">
          <geom pos="0 0 0.0423" material="allegro_white" mesh="link_15.0_tip"/>
        </default>
      </default>

      <default class="allegro_collision">
