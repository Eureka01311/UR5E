      <geom name="wall_right" type="box" size="0.01 0.13 0.1" pos="0.19 0 0.1" rgba="0.82 0.62 0.44 1"/>
      
      <site name="basket_center" pos="0 0 0.05" size="0.01" rgba="1 0 0 0"/>
    </body>

    <body name="apple_tree_1" pos="-0.6 -0.6 0"> 
      <geom name="tree_trunk" type="cylinder" size="0.04 0.4" pos="0 0 0.4" material="trunk_mat"/>
      <geom name="tree_leaves" type="sphere" size="0.3" pos="0 0 1.0" material="leaf_mat" contype="0" conaffinity="0"/>

      <body name="tree_branch_1" pos="0 0 0.6" axisangle="0 1 1 1.92">
        <geom name="branch_1_geom" type="capsule" size="0.015 0.18" pos="0 0 0.18" material="trunk_mat" contype="0" conaffinity="0"/>
        <site name="hook_apple_3" pos="0 0 0.36" size="0.01" rgba="1 0 0 1"/> 
      </body>

      <body name="tree_branch_2" pos="0 0 0.6" axisangle="1 0 0 -1.92">
        <geom name="branch_2_geom" type="capsule" size="0.015 0.12" pos="0 0 0.12" material="trunk_mat" contype="0" conaffinity="0"/>
        <site name="hook_apple_4" pos="0 0 0.24" size="0.01" rgba="1 0 0 1"/>
      </body>
    </body>

    <body name="apple_1" pos="-0.49 -0.52 0.77">
        <freejoint name="joint_apple_1"/>
        <geom name="apple_1_geom" type="mesh" mesh="apple_mesh" material="apple_mat" mass="0.1" friction="2.0 0.5 0.01"/>
        <site name="apple_force_site_1" pos="0 0 0"/>
